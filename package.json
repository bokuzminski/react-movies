    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-query": "3.39.3",
    "react-router": "7.13.2",
    "react-router-dom": "7.13.2",
    "shadcn": "4.0.8",
    "tailwind-merge": "3.5.0",
